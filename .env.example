# ---------------------------------------------------------------------------
# Talisman Forge environment variables
# Copy this file to .env.local and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# Auth.js (next-auth v5)
# Generate a secret with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"

# GitHub OAuth app credentials (https://github.com/settings/developers)
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# Public site URL (used for OAuth callbacks in production)
# AUTH_URL="https://your-domain.vercel.app"

# Database (Supabase Postgres) - used by Prisma
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Stripe (billing) - optional until billing is wired up
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
